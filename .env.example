# skypilot-llms — user-specific config
# Copy to `.env` and fill in. `.env` is gitignored.
# Every value here is consumed by sky.yaml via its `envs:` block.

# ───────────────────────────────── Required ─────────────────────────────────

# Public hostname for your llama.cpp endpoint (must be a CF-managed domain).
# Example: llm.yourdomain.com
LLM_HOSTNAME=

# Cloudflare Tunnel token. Create a named tunnel at
#   https://one.dash.cloudflare.com/ → Networks → Tunnels → Create tunnel
# Configure its public hostname to route ${LLM_HOSTNAME} → http://localhost:8080.
# Copy the "token" it shows under "Install and run a connector".
CF_TUNNEL_TOKEN=

# API key clients must send as `Authorization: Bearer <key>` to hit llama-server.
# Generate a random one: `openssl rand -hex 32`
LLM_API_KEY=

# RunPod API key. Create at https://www.runpod.io/console/user/settings → API Keys.
# SkyPilot reads this to provision GPUs. Also set via `sky check runpod` flow.
RUNPOD_API_KEY=

# ───────────────────────────────── Model ─────────────────────────────────

# HuggingFace repo + GGUF filename for the model llama-server loads on launch.
# Default: SmolLM2-360M-Instruct — ~230 MB, downloads in seconds, stack-test model.
# To try a bigger model, just change these two values.
LLM_HF_REPO=ggml-org/SmolLM2-360M-Instruct-GGUF
LLM_HF_FILE=SmolLM2-360M-Instruct-Q8_0.gguf

# ───────────────────────────────── Optional ─────────────────────────────────

# HuggingFace token. Only needed for gated models (Llama, Gemma, etc.).
HF_TOKEN=

# Auto-shutdown: exit the SkyPilot job after this many minutes with zero API
# activity. Combined with SkyPilot's `--down`, this terminates the cluster.
IDLE_MINUTES=15

# Wall-clock safety net: force shutdown after this many minutes no matter what.
# Protects against a wedged idle-watcher leaving the GPU running overnight.
MAX_RUNTIME_MINUTES=240

# Monthly USD cap for the budget-check script (scripts/budget-check.sh).
# The real backstop is a provider-side spend limit — set that too at
# https://www.runpod.io/console/user/billing
MONTHLY_BUDGET_USD=50
